# GitHub OAuth (required for login)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Session security (generate: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-random-hex-string

# Comma-separated GitHub usernames allowed to access (empty = any GitHub account)
ALLOWED_GITHUB_USERS=your-github-username

# Public URL of this app (must match OAuth callback URL in GitHub)
# Railway: use your Railway domain
BASE_URL=https://daily-focus.up.railway.app

# ── Railway 추가 설정 ───────────────────────────────────────────
# PORT is injected automatically by Railway — do not set manually

# Big Brother inter-service URL (Railway internal network)
BIG_BROTHER_URL=http://big-brother.railway.internal:8080
